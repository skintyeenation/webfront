# Headless WordPress (content: pages/news/projects/programs/jobs). Server-side.
WP_API_URL=http://localhost:8080

# The NestJS api/ server (events, notifications, meetings, governance, funding).
# The website always reads it as the anonymous `public` role.
API_URL=http://localhost:4000

# Where the signed-in "Onboarding" link/CTA points (SharePoint later).
ONBOARDING_URL=/onboarding

# Microsoft Entra (M365) sign-in via NextAuth. Generate AUTH_SECRET with
# `openssl rand -base64 32`. The Entra app-registration values come from your
# tenant (single-tenant is fine). Until these are set, sign-in is a no-op and the
# site stays fully public.
AUTH_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0

# App download links (App Store / Google Play). Default '#' until published.
APP_STORE_URL=
PLAY_STORE_URL=
