FROM ubuntu:24.04
ENV TARGETARCH="linux-x64"

# Remove this - it will be handled by Docker socket mount
# ENV DOCKER_HOST=tcp://localhost:2375

RUN apt update && \
  apt upgrade -y && \
  apt install -y \
    curl \
    git \
    jq \
    libicu74 \
    docker.io \
    docker-compose \
    coreutils \
    nano \
    openssh-client \
    openssh-server \
    ca-certificates && \
  rm -rf /var/lib/apt/lists/*

# Install Azure CLI
RUN curl -sL https://aka.ms/InstallAzureCLIDeb | bash

WORKDIR /azp/

COPY ./start.sh /usr/local/bin/start.sh
RUN sed -i 's/\r$//' /usr/local/bin/start.sh && chmod +x /usr/local/bin/start.sh

# Create agent user and set up home directory
RUN useradd -m -d /home/agent agent && \
    chown -R agent:agent /azp /home/agent

# Add agent user to docker group (GID 999 is common for docker socket)
RUN groupadd -g 999 docker 2>/dev/null || groupmod -g 999 docker && \
    usermod -aG docker agent

USER agent

ENTRYPOINT [ "/usr/local/bin/start.sh" ]
