# Skin Tyee Azure DevOps build-agent configuration.
#
# Copy this to .env.skintyeenation and fill in the AZP_TOKEN.
# .env.skintyeenation is git-ignored — it contains a secret.

# The ADO organization URL.
AZP_URL=https://dev.azure.com/skintyeenation

# Personal Access Token. Generate at
#   https://dev.azure.com/skintyeenation/_usersSettings/tokens
# Scope required: "Agent Pools (Read & manage)".
# Recommended lifetime: 90 days (rotate via the same UI when it expires).
AZP_TOKEN=replace-with-your-pat

# Agent pool name (created in ADO at
#   https://dev.azure.com/skintyeenation/_settings/agentpools ).
# Pipelines reference this name via `pool: name: <this>` in YAML.
AZP_POOL=skintyee-pool
