# Copy to .env and fill in. deploy-guacamole.sh ships this to the host.
# Never commit the real .env (only this .example).

# Public hostname (DNS A record must point at the host; Caddy auto-issues TLS).
GUAC_DOMAIN=remote.skintyee.ca

# Postgres (local to the stack unless you repoint at skintyee-prod-pg).
DB_NAME=guacamole_db
DB_USER=guacamole
DB_PASSWORD=change-me-strong

# Entra ID (OpenID) SSO — the skintyee-guacamole app registration.
ENTRA_TENANT_ID=ee46daed-e89f-4438-b1f7-dc26203a4bec
ENTRA_CLIENT_ID=
