{
  "$schema": "https://raw.githubusercontent.com/expo/eas-cli/main/packages/eas-json/schema/eas-json.json",
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "EXPO_PUBLIC_API_SERVER": "mock"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_SERVER": "https://api.skintyee.ca"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_SERVER": "https://api.skintyee.ca"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "replace-with-apple-id@skintyee.ca",
        "ascAppId": "replace-with-app-store-connect-app-id",
        "appleTeamId": "replace-with-apple-team-id"
      },
      "android": {
        "track": "internal",
        "serviceAccountKeyPath": "./.eas/google-service-account.json"
      }
    }
  }
}
