{
  "name": "@skintyee/app",
  "version": "0.0.0",
  "private": true,
  "description": "Skin Tyee First Nation community app",
  "author": "Skin Tyee First Nation",
  "homepage": "https://skintyee.ca",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client",
    "web": "expo start --web",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "typecheck": "tsc --noEmit",
    "web:export:electron": "cross-env ELECTRON_BUILD=1 expo export:web",
    "desktop:dev": "cross-env ELECTRON_DEV=1 electron electron/main.js",
    "desktop:build": "pnpm run web:export:electron && electron-builder",
    "desktop:build:win": "pnpm run web:export:electron && electron-builder --win",
    "desktop:build:linux": "pnpm run web:export:electron && electron-builder --linux",
    "desktop:build:mac": "pnpm run web:export:electron && electron-builder --mac"
  },
  "dependencies": {
    "@skintyee/api-client": "workspace:*",
    "@skintyee/models": "workspace:*",
    "@react-native-async-storage/async-storage": "~1.17.11",
    "@react-navigation/material-bottom-tabs": "~6.2.2",
    "@react-navigation/native": "~6.0.11",
    "@react-navigation/stack": "~6.2.2",
    "@reduxjs/toolkit": "~1.9.1",
    "d3-hierarchy": "^3.1.2",
    "d3-shape": "^3.2.0",
    "expo": "~48.0.21",
    "expo-auth-session": "~4.0.3",
    "expo-constants": "~14.2.1",
    "expo-crypto": "~12.2.1",
    "expo-document-picker": "^56.0.4",
    "expo-font": "~11.1.1",
    "expo-image-picker": "~14.1.1",
    "expo-status-bar": "~1.4.4",
    "expo-web-browser": "~12.1.1",
    "moment": "~2.29.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-is": "18.2.0",
    "react-native": "0.71.14",
    "react-native-gesture-handler": "~2.9.0",
    "react-native-loading-spinner-overlay": "~3.0.1",
    "react-native-paper": "~5.11.7",
    "react-native-safe-area-context": "^4.5.0",
    "react-native-screens": "~3.20.0",
    "react-native-svg": "13.4.0",
    "react-native-vector-icons": "~9.2.0",
    "react-native-web": "~0.18.9",
    "react-redux": "~8.0.5",
    "redux": "~4.2.0",
    "redux-thunk": "~2.4.2"
  },
  "devDependencies": {
    "@babel/core": "~7.29.0",
    "@expo/webpack-config": "^18.1.4",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-shape": "^3.1.8",
    "@types/react": "~18.0.24",
    "@types/react-native": "~0.70.6",
    "@types/react-native-vector-icons": "~6.4.12",
    "babel-plugin-module-resolver": "~4.1.0",
    "babel-preset-expo": "~9.3.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "metro-react-native-babel-preset": "~0.73.6",
    "typescript": "~5.4.5"
  },
  "build": {
    "appId": "ca.skintyee.desktop",
    "productName": "Skin Tyee",
    "copyright": "© Skin Tyee First Nation",
    "electronVersion": "31.7.7",
    "artifactName": "SkinTyee-${version}-${arch}.${ext}",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "directories": {
      "output": "desktop-dist",
      "buildResources": "electron/resources"
    },
    "files": [
      "electron/**/*",
      "web-build/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "maintainer": "Skin Tyee First Nation <it@skintyee.ca>"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.business"
    }
  }
}
