{
  "name": "@skintyee/api",
  "version": "0.1.0",
  "private": true,
  "description": "Skin Tyee API — contract-first (OpenAPI) server scaffold for the app backend.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint:openapi": "swagger-cli validate openapi.yaml"
  },
  "dependencies": {
    "cors": "~2.8.5",
    "express": "~4.19.2",
    "js-yaml": "~4.1.0",
    "swagger-ui-express": "~5.0.1"
  },
  "devDependencies": {
    "@apidevtools/swagger-cli": "~4.0.4",
    "@types/cors": "~2.8.17",
    "@types/express": "~4.17.21",
    "@types/js-yaml": "~4.0.9",
    "@types/node": "~20.11.30",
    "@types/swagger-ui-express": "~4.1.6",
    "ts-node-dev": "~2.0.0",
    "typescript": "~5.4.5"
  }
}
