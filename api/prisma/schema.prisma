// Prisma schema for the Skin Tyee api/. Per ADR-7 (NestJS + Prisma +
// Azure PostgreSQL Flexible Server). PostGIS-enabled when we add
// geo data; for now this only covers the BandMember directory,
// seeded from Microsoft Entra via the api/'s skintyee-app-graph
// application credential.
//
// Other entities (events, notifications, meetings, transparency,
// timekeeping, financials, polls) stay in DataService's in-memory
// store until they're each migrated to Postgres in Phase 2 of the
// per-entity rollout. This keeps the initial Prisma scope small +
// reviewable.

generator client {
  provider      = "prisma-client-js"
  // Generate engines for the Alpine (musl) runtime our Docker image uses.
  // Without this Prisma picks the wrong libssl variant at runtime —
  // saw 'Defaulting to openssl-1.1.x' + 'Unable to require .so.node'
  // because node:22-alpine ships openssl 3, not 1.1. Pinning both
  // targets so local (darwin/linux) dev still works alongside prod.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- AppSetting -----------------------------------------------------------
// Generic key/value store for admin-configurable runtime settings (e.g. the
// notification-settings blob: per-category email toggles + sender/reply-to).
// Value is a JSON string owned by SettingsService; degrades to in-memory in
// that service when Prisma isn't connected.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ---- BandMember -----------------------------------------------------------
// Seeded from Entra users in the skintyeenation tenant by
// /v1/admin/seed-directory (calls GraphFeedService.getDirectory()).
// Key is the Entra user's object id (.id from /users); UPN is unique.

model BandMember {
  id                 String  @id // Entra object id (oid)
  upn                String  @unique // userPrincipalName, lowercased
  email              String?
  name               String
  role               String // "Member" | "Staff" | "Chief" | "Council"
  title              String?
  department         String?
  phone              String?
  avatarLetter       String?
  appRole            String  @default("member") // "public" | "member" | "staff" | "admin" — for the app's role-gating
  // What kind of Entra account this is:
  //   "licensed-user"  — a real person with an M365 license (chief, councillors, staff members)
  //   "shared-inbox"   — a shared mailbox / role mailbox (info@, finance@, housing@, etc.)
  // Derived in GraphFeedService.getDirectory() from the user's assignedLicenses
  // array (length > 0 → licensed-user; empty → shared-inbox).
  accountType        String  @default("licensed-user")
  // For licensed users: which shared mailboxes / mail-enabled groups they
  // have access to. Comma-separated UPN/mail list, e.g.:
  //   "council@skintyee.ca,management@skintyeenation.onmicrosoft.com"
  // Populated from TWO sources:
  //   1. Microsoft Graph /users/{id}/memberOf — gives M365 Group memberships
  //      (mail-enabled groups represent shared mailboxes the user can access
  //      via their group membership). Auto-populated on seed.
  //   2. Manual admin entry — for CLASSIC shared mailboxes (chief@,
  //      councillor1@, etc.) where permissions are stored in Exchange
  //      Online's Get-MailboxPermission and aren't exposed in Graph v1.0.
  //      Admins set these via POST /v1/admin/users/{id}/mailbox-memberships.
  mailboxMemberships String  @default("")

  // Managed-catalog Microsoft licences the user holds. Comma-separated
  // skuPartNumbers from GraphFeedService.LICENSE_CATALOG, e.g.:
  //   "O365_BUSINESS_PREMIUM,AAD_PREMIUM"
  // Seeded from the user's Entra assignedLicenses; admins toggle these via
  // PATCH /v1/directory/:id/licenses. Drives the EditMember "Licenses"
  // section + the directory "Entra P1 / paid" badge.
  licenses String @default("")

  // Skin Tyee Entra security-group memberships. Comma-separated slugs
  // from src/skintyee-groups.ts (SKINTYEE_SECURITY_GROUPS), e.g.:
  //   "admins,management,it"
  // This is the app's "role" model — multi-valued, mirrored 1:1 from
  // Entra security groups. Read from Graph on seed (walks each catalog
  // group's /members). Edits in the app's EditMember screen call
  // PATCH /v1/directory/:id/groups which diffs vs Entra and writes
  // back via POST/DELETE /groups/{id}/members/$ref (requires the
  // Group.ReadWrite.All application permission).
  bandGroups String @default("")

  // Manager (the user's manager in the org chart). Pulled from
  // /users/{id}/manager. Nullable — not everyone has a manager set.
  managerId   String?
  managerName String?
  managerUpn  String?

  // Photo metadata. The actual binary is fetched on demand from
  // /users/{id}/photo/$value via the api/'s /v1/directory/:id/photo
  // proxy endpoint, which streams from Graph + sets cache headers.
  // hasPhoto is checked during seed; if true the UI can render
  // <Avatar.Image source={…/photo}/> instead of the letter fallback.
  hasPhoto  Boolean  @default(false)
  enabled   Boolean  @default(true)
  syncedAt  DateTime @default(now()) // last time seeded from Entra
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Reverse side of the optional 1:1 Person <-> BandMember link
  // (set when an admin links a Person row to this band member).
  person    Person?

  @@index([upn])
  @@index([enabled])
  @@index([accountType])
}

// ---- Timesheets ----------------------------------------------------------
// Bi-weekly timesheets per worker per pay-period. See
// docs/features/timesheets.md for the full design — pay periods are
// derived from api/src/skintyee-pay-periods.ts (no DB rows for periods
// themselves, they're a function of the anchor cutoff + length).
//
// Lifecycle: draft → submitted → approved | rejected. Rejected returns
// to draft for the worker to edit + resubmit.
//
// OT rule: hours > 40 in either week of the 14-day period bumps
// requiresAdminApproval=true; band-manager approvals are then blocked
// and only an admin can sign off.

model Timesheet {
  id          String  @id // <workerUpn>:<payPeriodId>
  workerUpn   String
  workerName  String
  payPeriodId String // YYYY-MM-DD of the cutoff Friday
  status      String  @default("draft") // draft | submitted | approved | rejected
  notes       String?

  // Computed at submit-time + persisted so the approval queue can
  // sort/filter without re-summing the entries. Updated again on
  // any edit while still in draft.
  week1Hours            Float   @default(0)
  week2Hours            Float   @default(0)
  totalHours            Float   @default(0)
  overtimeHours         Float   @default(0)
  requiresAdminApproval Boolean @default(false)

  submittedAt    DateTime?
  approvedBy     String? // approver's UPN
  approvedAt     DateTime?
  rejectedReason String?

  entries   TimesheetEntry[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([workerUpn, payPeriodId])
  @@index([payPeriodId, status])
  @@index([workerUpn])
}

// Generated PDF report for a single pay period — admin clicks Generate
// on the Reports screen and the api/ builds a printable PDF of every
// worker's timesheet in that period + uploads it via the active storage
// adapter (Blob today, SharePoint when wired). Idempotent on regenerate:
// re-running drops the old blob and replaces with a fresh one.
model TimesheetReport {
  id          String   @id @default(cuid())
  payPeriodId String   @unique // YYYY-MM-DD of cutoff Friday
  // Storage adapter that owns fileKey (same shape as Document).
  storage     String // 'blob' | 'sharepoint'
  fileKey     String
  fileUrl     String?
  fileName    String
  mimeType    String   @default("application/pdf")
  sizeBytes   Int
  // Snapshot of the underlying data at generation time — cheap totals
  // the Reports list can sort / preview by.
  workerCount Int      @default(0)
  totalHours  Float    @default(0)
  generatedAt DateTime @default(now())
  generatedBy String // admin's UPN
}

// Named TimesheetEntry (not TimeEntry) so it doesn't collide with the
// in-memory legacy TimeEntry type the existing TimeKeeping page uses
// until that UI is rewritten.
model TimesheetEntry {
  id          String    @id @default(cuid())
  timesheetId String
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  date        String // YYYY-MM-DD within the period

  // Workers can enter hours either as raw decimal (`8.5`) OR as
  // clock-in/clock-out ("08:00" → "16:30"). The UI fills in `hours`
  // from the times client-side; `timeIn` + `timeOut` are persisted
  // so the original clock-time is auditable / re-editable.
  hours   Float
  timeIn  String? // "HH:mm" 24h, e.g. "08:00"
  timeOut String? // "HH:mm" 24h, e.g. "16:30"
  task    String

  @@index([timesheetId, date])
}

// ---- Expenses --------------------------------------------------------------
// Staff submit expense claims (a batch of receipt items) for reimbursement;
// finance (BandMember.bandGroups contains 'finance') or admins approve. Mirrors
// the Timesheet lifecycle: draft → submitted → approved | rejected (+ reopen).
model ExpenseClaim {
  id            String  @id // <submitterUpn>:<payPeriodId>
  submitterUpn  String
  submitterName String
  payPeriodId   String // YYYY-MM-DD cutoff Friday — SAME pay periods as timesheets
  title         String?
  status        String  @default("draft") // draft | submitted | approved | rejected
  notes         String?
  // Snapshot total of the items, recomputed on each edit.
  totalAmount   Float   @default(0)
  currency      String  @default("CAD")

  submittedAt    DateTime?
  approvedBy     String? // approver's UPN
  approvedAt     DateTime?
  rejectedReason String?

  items     ExpenseItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([submitterUpn, payPeriodId])
  @@index([payPeriodId, status])
  @@index([submitterUpn])
}

model ExpenseItem {
  id          String       @id @default(cuid())
  claimId     String
  claim       ExpenseClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  date        String? // YYYY-MM-DD receipt date
  vendor      String?
  amount      Float        @default(0) // claimed amount (sum of included line items + tax when itemised)
  taxAmount   Float? // tax portion (GST/PST/HST) of the receipt
  currency    String? // per-receipt ISO currency; falls back to the claim currency
  tagSlug     String? // → ExpenseTag.slug (the expense category)
  description String?
  aiExtracted Boolean      @default(false) // amount/vendor/date were AI-prefilled
  // AI-itemised receipt lines when the photo was legible:
  //   [{description, amount, qty, excluded}]  — `excluded` lines are struck out
  //   in the UI and dropped from the claimed amount.
  lineItems   Json?

  // Receipt file — same storage shape as Document / TimesheetReport.
  storage   String? // 'blob' | 'sharepoint'
  fileKey   String?
  fileUrl   String?
  fileName  String?
  mimeType  String?
  sizeBytes Int?

  @@index([claimId])
}

// Admin-editable "tags" catalog (the expense categories) — managed like the
// Document Tag Manager, seeded with standard expense items (expense-tags.seed.ts).
model ExpenseTag {
  slug      String   @id
  label     String
  // General Ledger account number this category posts to — the accounting
  // key finance uses to map a tagged receipt into Adagio / Sage 300 (ASAP).
  glAccount String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ---- Documents ------------------------------------------------------------
// Admin-managed library of band documents (forms, gov filings, contractor
// packets). Backed by a pluggable storage adapter — Azure Blob today,
// SharePoint behind a feature flag (STORAGE_DRIVER=sharepoint). See
// docs/features/documents-and-onboarding.md for the full plan.
//
// A doc can carry a PDF (`fileKey` + `fileUrl`) OR an external URL
// (`linkUrl`) OR both — controller validates "at least one of".
//
// Visibility is per-document via `audience`; controller filters list +
// detail by the caller's role (admin sees everything; staff sees staff
// + below; band_member sees band_member + public; unauthenticated sees
// only public).
//
// `companyId` is a placeholder column for Phase 2 onboarding — the field
// is exposed on the API + UI as disabled / "Coming soon" until the
// Company catalog ships.

model Document {
  id          String  @id @default(cuid())
  title       String
  description String?

  // Storage-bound fields. `fileKey` is the adapter-internal handle (Blob
  // path or SharePoint driveItem id); `fileUrl` is a cached canonical
  // URL the client can render — controllers refresh it on detail reads
  // for adapters that issue short-lived URLs (Blob presigned SAS).
  storage   String? // 'blob' | 'sharepoint' — null when there's only a linkUrl
  fileKey   String?
  fileUrl   String?
  fileName  String?
  mimeType  String?
  sizeBytes Int?

  // External link companion. Renders next to / instead of the PDF.
  linkUrl String?

  // Per-document audience — drives controller-level read gating.
  // 'admin' / 'staff' / 'band_member' / 'public'.
  audience String @default("staff")

  // Future-use placeholder; nullable until the Company catalog lands.
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  tags DocumentTag[] @relation("DocumentTags")

  createdAt              DateTime                 @default(now())
  createdBy              String // UPN of uploading admin
  updatedAt              DateTime                 @updatedAt
  OnboardingStepDocument OnboardingStepDocument[]

  @@index([audience])
  @@index([companyId])
}

// Tag taxonomy — three categories, each with multiple values curated by
// admins via the Tag Manager UI. (slug, category) is the natural key;
// keeping `id` as the primary so renames / re-slugging don't break
// existing document associations.
model DocumentTag {
  id          String     @id @default(cuid())
  category    String // 'gov' | 'gov_sector' | 'department'
  slug        String // kebab-case, unique within category
  displayName String
  documents   Document[] @relation("DocumentTags")

  @@unique([category, slug])
  @@index([category])
}

// Placeholder Company catalog. Field exists so the foreign key on
// Document compiles; the UI exposes it disabled. Populated by admin
// UI in Phase 2 onboarding work.
model Company {
  id          String           @id @default(cuid())
  displayName String
  parentSlug  String // 'skintyee-management' for sub-companies of the main band
  active      Boolean          @default(true)
  documents   Document[]
  flows       OnboardingFlow[]
  people      Person[]
  createdAt   DateTime         @default(now())

  @@index([parentSlug, active])
}

// ---- Onboarding (Phase 2) -------------------------------------------------
//
// Admin-designed onboarding flows for new people (contractors, staff
// hires, volunteers — anyone going through a process). A flow is a
// reusable template of ordered steps; each step attaches Documents +
// arbitrary URLs and declares who completes it. A flow assigned to a
// Person becomes an OnboardingAssignment, and each step gets its
// own OnboardingStepState row tracking status + the person's
// uploaded file (if any). Visual + approval language is borrowed from
// the Timesheets feature — see docs/features/documents-and-onboarding.md.

model OnboardingFlow {
  id          String                 @id @default(cuid())
  title       String
  description String?
  companyId   String? // optional — same placeholder as Document.companyId
  company     Company?               @relation(fields: [companyId], references: [id])
  active      Boolean                @default(true)
  steps       OnboardingStep[]
  assignments OnboardingAssignment[]
  createdAt   DateTime               @default(now())
  createdBy   String // UPN of designing admin
  updatedAt   DateTime               @updatedAt

  @@index([active])
  @@index([companyId])
}

model OnboardingStep {
  id           String         @id @default(cuid())
  flowId       String
  flow         OnboardingFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  order        Int // 0-based; admin drag-handle reorder bumps these
  title        String
  instructions String? // markdown
  // Who completes the step.
  // 'admin_marks' | 'person_uploads' | 'both'
  completion   String         @default("admin_marks")

  documentLinks OnboardingStepDocument[]
  links         OnboardingStepLink[]

  @@index([flowId, order])
}

// Bridge — step references existing Document templates (the admin built
// in Phase 1). `personUploadAllowed` says whether this step expects
// the person to upload a replacement (e.g. signed form).
model OnboardingStepDocument {
  id                  String         @id @default(cuid())
  stepId              String
  step                OnboardingStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  documentId          String
  document            Document       @relation(fields: [documentId], references: [id])
  personUploadAllowed Boolean        @default(false)

  @@index([stepId])
  @@index([documentId])
}

// Free URL links on a step — admin-authored pointers to SharePoint
// folders, gov.ca form pages, anything.
model OnboardingStepLink {
  id     String         @id @default(cuid())
  stepId String
  step   OnboardingStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  label  String
  url    String

  @@index([stepId])
}

// Person — anyone the admin tracks onboarding progress for (contractors,
// staff hires, volunteers, externals…). Optionally linked 1:1 to a
// BandMember when the person IS also a band member with an Entra
// identity; for everyone else (most contractors), bandMemberId is null
// and displayName/email/phone are filled in by the admin directly.
// Full auth / portal accounts are future work; for now they interact
// via tokenised public links.
model Person {
  id                String                 @id @default(cuid())
  displayName       String
  // Email — also the password-auth login identifier when this Person
  // has no linked BandMember (contractor / external staff). Stored
  // lowercased at write time so login lookups are case-insensitive.
  // Nullable for legacy rows / Persons tracked for onboarding only.
  email             String?                @unique
  phone             String?
  companyId         String?
  company           Company?               @relation(fields: [companyId], references: [id])
  // Optional 1:1 link to a BandMember (Entra-backed). When set, the
  // linked member's name/email/phone are the source of truth and the
  // Person row's fields are kept in sync at save time. Setting this
  // also nulls passwordHash / resetToken in the same transaction —
  // see docs/features/staff-auth.md "Lifecycle: password → linked".
  bandMemberId      String?                @unique
  bandMember        BandMember?            @relation(fields: [bandMemberId], references: [id])
  // Gates whether this Person shows up in Time Keeping. Off by default
  // so existing contractor records (added before the feature) don't
  // suddenly appear in the Approvals roster.
  timesheetsEnabled Boolean                @default(false)
  // Same gate for the Expenses module — who can submit expense claims.
  expensesEnabled   Boolean                @default(false)
  // ---- Password-auth (staff-auth feature) -----------------------------
  // Only populated for Persons WITHOUT a bandMemberId. Setting any of
  // these on a Person with a linked BandMember is rejected at the
  // service layer — they use Entra SSO instead.
  passwordHash      String?
  passwordSetAt     DateTime?
  resetToken        String?                @unique
  resetTokenAt      DateTime?
  lastSignInAt      DateTime?
  // Default role for the password-auth path is 'staff'. Promote to
  // 'admin' is a deliberate admin-grant via a separate endpoint, not
  // the AddPerson form. Null falls back to 'staff' at read time.
  appRole           String?                @default("staff")
  assignments       OnboardingAssignment[]
  createdAt         DateTime               @default(now())

  @@index([companyId])
  @@index([timesheetsEnabled])
}

model OnboardingAssignment {
  id          String                @id @default(cuid())
  flowId      String
  flow        OnboardingFlow        @relation(fields: [flowId], references: [id])
  personId    String
  person      Person                @relation(fields: [personId], references: [id])
  // Hex token for the public link. Treated as a bearer secret — anyone
  // with it can view the assignment + upload to steps that allow it.
  // Re-issue via POST /assignments/:id/rotate-token.
  publicToken String                @unique
  startedAt   DateTime              @default(now())
  completedAt DateTime?
  stepStates  OnboardingStepState[]

  @@index([flowId])
  @@index([personId])
}

model OnboardingStepState {
  id              String               @id @default(cuid())
  assignmentId    String
  assignment      OnboardingAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  // Loose reference (no FK) so reordering / editing the flow doesn't
  // cascade into assignment history. The UI resolves stepId → step on
  // read.
  stepId          String
  status          String               @default("pending") // pending | in_progress | completed | rejected
  // Person's upload, when the step expects one. Same adapter as
  // Document.fileKey / fileUrl — the StepState owns its own file
  // separate from the step's template Document.
  personStorage   String? // 'blob' | 'sharepoint'
  personFileKey   String?
  personFileUrl   String?
  personFileName  String?
  personMimeType  String?
  personSizeBytes Int?
  notes           String? // admin-authored rejection / completion notes
  completedAt     DateTime?
  completedBy     String? // UPN or 'person' for self-upload-to-complete steps

  @@unique([assignmentId, stepId])
  @@index([status])
}
