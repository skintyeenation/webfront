// Prisma schema for the Skin Tyee api/. Per ADR-7 (NestJS + Prisma +
// Azure PostgreSQL Flexible Server). PostGIS-enabled when we add
// geo data; for now this only covers the BandMember directory,
// seeded from Microsoft Entra via the api/'s skintyee-app-graph
// application credential.
//
// Other entities (events, notifications, meetings, transparency,
// timekeeping, financials, polls) stay in DataService's in-memory
// store until they're each migrated to Postgres in Phase 2 of the
// per-entity rollout. This keeps the initial Prisma scope small +
// reviewable.

generator client {
  provider      = "prisma-client-js"
  // Generate engines for the Alpine (musl) runtime our Docker image uses.
  // Without this Prisma picks the wrong libssl variant at runtime —
  // saw 'Defaulting to openssl-1.1.x' + 'Unable to require .so.node'
  // because node:22-alpine ships openssl 3, not 1.1. Pinning both
  // targets so local (darwin/linux) dev still works alongside prod.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- BandMember -----------------------------------------------------------
// Seeded from Entra users in the skintyeenation tenant by
// /v1/admin/seed-directory (calls GraphFeedService.getDirectory()).
// Key is the Entra user's object id (.id from /users); UPN is unique.

model BandMember {
  id            String   @id              // Entra object id (oid)
  upn           String   @unique           // userPrincipalName, lowercased
  email         String?
  name          String
  role          String                     // "Member" | "Staff" | "Chief" | "Council"
  title         String?
  department    String?
  phone         String?
  avatarLetter  String?
  appRole       String   @default("member") // "public" | "member" | "staff" | "admin" — for the app's role-gating
  // What kind of Entra account this is:
  //   "licensed-user"  — a real person with an M365 license (chief, councillors, staff members)
  //   "shared-inbox"   — a shared mailbox / role mailbox (info@, finance@, housing@, etc.)
  // Derived in GraphFeedService.getDirectory() from the user's assignedLicenses
  // array (length > 0 → licensed-user; empty → shared-inbox).
  accountType   String   @default("licensed-user")
  // For licensed users: which shared mailboxes / mail-enabled groups they
  // have access to. Comma-separated UPN/mail list, e.g.:
  //   "council@skintyee.ca,management@skintyeenation.onmicrosoft.com"
  // Populated from TWO sources:
  //   1. Microsoft Graph /users/{id}/memberOf — gives M365 Group memberships
  //      (mail-enabled groups represent shared mailboxes the user can access
  //      via their group membership). Auto-populated on seed.
  //   2. Manual admin entry — for CLASSIC shared mailboxes (chief@,
  //      councillor1@, etc.) where permissions are stored in Exchange
  //      Online's Get-MailboxPermission and aren't exposed in Graph v1.0.
  //      Admins set these via POST /v1/admin/users/{id}/mailbox-memberships.
  mailboxMemberships String @default("")

  // Skin Tyee Entra security-group memberships. Comma-separated slugs
  // from src/skintyee-groups.ts (SKINTYEE_SECURITY_GROUPS), e.g.:
  //   "admins,management,it"
  // This is the app's "role" model — multi-valued, mirrored 1:1 from
  // Entra security groups. Read from Graph on seed (walks each catalog
  // group's /members). Edits in the app's EditMember screen call
  // PATCH /v1/directory/:id/groups which diffs vs Entra and writes
  // back via POST/DELETE /groups/{id}/members/$ref (requires the
  // Group.ReadWrite.All application permission).
  bandGroups   String   @default("")

  // Manager (the user's manager in the org chart). Pulled from
  // /users/{id}/manager. Nullable — not everyone has a manager set.
  managerId    String?
  managerName  String?
  managerUpn   String?

  // Photo metadata. The actual binary is fetched on demand from
  // /users/{id}/photo/$value via the api/'s /v1/directory/:id/photo
  // proxy endpoint, which streams from Graph + sets cache headers.
  // hasPhoto is checked during seed; if true the UI can render
  // <Avatar.Image source={…/photo}/> instead of the letter fallback.
  hasPhoto     Boolean  @default(false)
  enabled       Boolean  @default(true)
  syncedAt      DateTime @default(now())   // last time seeded from Entra
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([upn])
  @@index([enabled])
  @@index([accountType])
}

// ---- Timesheets ----------------------------------------------------------
// Bi-weekly timesheets per worker per pay-period. See
// docs/features/timesheets.md for the full design — pay periods are
// derived from api/src/skintyee-pay-periods.ts (no DB rows for periods
// themselves, they're a function of the anchor cutoff + length).
//
// Lifecycle: draft → submitted → approved | rejected. Rejected returns
// to draft for the worker to edit + resubmit.
//
// OT rule: hours > 40 in either week of the 14-day period bumps
// requiresAdminApproval=true; band-manager approvals are then blocked
// and only an admin can sign off.

model Timesheet {
  id            String   @id              // <workerUpn>:<payPeriodId>
  workerUpn     String
  workerName    String
  payPeriodId   String                    // YYYY-MM-DD of the cutoff Friday
  status        String   @default("draft")  // draft | submitted | approved | rejected
  notes         String?

  // Computed at submit-time + persisted so the approval queue can
  // sort/filter without re-summing the entries. Updated again on
  // any edit while still in draft.
  week1Hours    Float    @default(0)
  week2Hours    Float    @default(0)
  totalHours    Float    @default(0)
  overtimeHours Float    @default(0)
  requiresAdminApproval Boolean @default(false)

  submittedAt    DateTime?
  approvedBy     String?              // approver's UPN
  approvedAt     DateTime?
  rejectedReason String?

  entries       TimesheetEntry[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([workerUpn, payPeriodId])
  @@index([payPeriodId, status])
  @@index([workerUpn])
}

// Named TimesheetEntry (not TimeEntry) so it doesn't collide with the
// in-memory legacy TimeEntry type the existing TimeKeeping page uses
// until that UI is rewritten.
model TimesheetEntry {
  id          String   @id @default(cuid())
  timesheetId String
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  date        String   // YYYY-MM-DD within the period

  // Workers can enter hours either as raw decimal (`8.5`) OR as
  // clock-in/clock-out ("08:00" → "16:30"). The UI fills in `hours`
  // from the times client-side; `timeIn` + `timeOut` are persisted
  // so the original clock-time is auditable / re-editable.
  hours       Float
  timeIn      String?      // "HH:mm" 24h, e.g. "08:00"
  timeOut     String?      // "HH:mm" 24h, e.g. "16:30"
  task        String

  @@index([timesheetId, date])
}
